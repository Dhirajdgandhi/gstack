# Network Hub — copy to .env and fill in your keys

# App URLs (defaults work for local dev)
APP_URL=http://localhost:5173
API_URL=http://localhost:8787
PORT=8787

# Auth — required on Vercel; auto-generated locally in ~/.network-hub/.jwt-secret if omitted
# JWT_SECRET=

# Vercel auto-sets VERCEL_URL — used for APP_URL/API_URL/OAuth redirect when unset
# APP_URL=https://your-project.vercel.app
# API_URL=https://your-project.vercel.app

# ─── Google Calendar (required for calendar sync) ───────────────────────────
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable Google Calendar API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Authorized redirect URI: http://localhost:8787/api/auth/google/callback
# Google credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# Axon AI shared calendar only (defaults to the team calendar if omitted).
# Paste the calendar ID or the full Google Calendar share link:
# GOOGLE_CALENDAR_URL=https://calendar.google.com/calendar/u/0?cid=...
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ─── LinkedIn URL auto-fetch (optional — PDF upload works without this) ─────
# PROXYCURL_API_KEY=

# ─── Optional: smarter meeting prep summaries ───────────────────────────────
# OPENAI_API_KEY=
