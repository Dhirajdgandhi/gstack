# Network Hub — copy to .env and fill in your keys

# App URLs (defaults work for local dev)
APP_URL=http://localhost:5173
API_URL=http://localhost:8787
PORT=8787

# Auth — required on Vercel; auto-generated locally in ~/.network-hub/.jwt-secret if omitted
# JWT_SECRET=

# Restrict sign-in to team Google accounts (comma-separated domains or explicit emails)
# TEAM_EMAILS=alice@axon.ai,bob@axon.ai,charlie@axon.ai
# Anyone with Google can authenticate; only TEAM_EMAILS sees team intelligence.

# Local dev only: re-enable username/password login (disabled in production by default)
# ALLOW_PASSWORD_AUTH=1

# Vercel auto-sets VERCEL_URL — used for APP_URL/API_URL/OAuth redirect when unset
# APP_URL=https://your-project.vercel.app
# API_URL=https://your-project.vercel.app

# Docker / Lightsail (same origin — nginx serves web + proxies /api)
# APP_URL=http://YOUR_PUBLIC_IP_OR_DOMAIN
# API_URL=http://YOUR_PUBLIC_IP_OR_DOMAIN
# GOOGLE_REDIRECT_URI=http://YOUR_PUBLIC_IP_OR_DOMAIN/api/auth/google/callback

# ─── PostgreSQL (required) ────────────────────────────────────────────────────
# Remote DB on another EC2 (recommended for production):
#   DATABASE_HOST=3.143.209.228       # DB server's IP (private IP if same VPC)
#   DATABASE_PORT=5432
#   DATABASE_USER=appuser
#   DATABASE_PASSWORD=...
#   DATABASE_NAME=myapp_db
#
# Or single URL:
# DATABASE_URL=postgresql://appuser:PASSWORD@3.143.209.228:5432/myapp_db
#
# Local bundled Postgres (docker compose up): compose overrides host to `postgres`.

# ─── Google Sign-In + Calendar (required) ─────────────────────────────────────
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable Google Calendar API
# 3. Configure OAuth consent screen (Internal for Workspace, or External + test users)
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Authorized redirect URI: http://localhost:8787/api/auth/google/callback
#    (production: https://your-app.vercel.app/api/auth/google/callback)
# Google credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# Axon AI shared calendar only (defaults to the team calendar if omitted).
# Paste the calendar ID or the full Google Calendar share link:
# GOOGLE_CALENDAR_URL=https://calendar.google.com/calendar/u/0?cid=...
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ─── LinkedIn URL auto-fetch (optional — PDF upload works without this) ─────
# PROXYCURL_API_KEY=

# ─── Optional: smarter meeting prep summaries ───────────────────────────────
# OPENAI_API_KEY=
