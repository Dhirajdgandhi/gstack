{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix web && npm install",
  "buildCommand": "npm run build --prefix web",
  "outputDirectory": "web/dist",
  "framework": null,
  "bunVersion": "1.x",
  "functions": {
    "api/**": {
      "maxDuration": 60
    }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
