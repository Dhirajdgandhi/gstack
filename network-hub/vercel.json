{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix web && npm install",
  "buildCommand": "npm run build --prefix web",
  "outputDirectory": "web/dist",
  "framework": null,
  "bunVersion": "1.x",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index?path=$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
